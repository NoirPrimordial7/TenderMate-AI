# Copy this file to backend/.env for local development.
# Never commit backend/.env or real secrets.

PROJECT_NAME=NividaIQ Backend
FRONTEND_URL=http://localhost:3000
# In production, FRONTEND_URL should be the deployed Vercel URL.
# Optional comma-separated extra frontend origins.
CORS_ORIGINS=

# Legal operator details. Complete and professionally review before launch.
LEGAL_ENTITY_NAME=
LEGAL_BUSINESS_ADDRESS=
LEGAL_CONTACT_EMAIL=
LEGAL_GRIEVANCE_OFFICER_NAME=
LEGAL_GRIEVANCE_OFFICER_EMAIL=
LEGAL_GOVERNING_STATE=Maharashtra
LEGAL_EFFECTIVE_DATE=
LEGAL_VERSION=1.0

SUPABASE_URL=
# Backend-only key. Do not expose SUPABASE_SERVICE_ROLE_KEY to the frontend.
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# Generate a strong local secret for JWT_SECRET_KEY before using auth.
# JWT_SECRET_KEY must be generated and kept secret.
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Security and quota defaults.
RATE_LIMIT_ENABLED=true
MAX_UPLOADS_PER_DAY=5
MAX_AI_ANALYSES_PER_DAY=3
FAILED_LOGIN_LOCK_THRESHOLD=5
FAILED_LOGIN_LOCK_MINUTES=15

# Gemini AI analysis. Backend-only; never expose this key to the frontend.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite
# MAX_GEMINI_INPUT_CHARS remains a supported legacy fallback.
MAX_MODEL_INPUT_CHARS=100000
GEMINI_REQUEST_TIMEOUT_SECONDS=60

# Provider-neutral model routing. Gemini remains the production default/fallback.
# Supported providers: gemini, openai_compatible
AI_PROVIDER=gemini
AI_FALLBACK_PROVIDER=gemini
# Leave blank and rate 0 to disable shadow evaluation.
AI_SHADOW_PROVIDER=
AI_SHADOW_SAMPLE_RATE=0
# Only these user UUIDs may trigger sampled shadow calls.
AI_SHADOW_USER_ALLOWLIST=

# Future backend-only Modal/vLLM OpenAI-compatible endpoint.
# Endpoint/models and the credentials for the selected auth mode are required.
TENDERMATE_MODEL_BASE_URL=
# bearer sends Authorization: Bearer; modal_proxy sends Modal-Key/Modal-Secret.
TENDERMATE_MODEL_AUTH_MODE=bearer
TENDERMATE_MODEL_API_KEY=
TENDERMATE_MODEL_MODAL_KEY=
TENDERMATE_MODEL_MODAL_SECRET=
TENDERMATE_ANALYSIS_MODEL=
TENDERMATE_ASSISTANT_MODEL=
TENDERMATE_MODEL_TIMEOUT_SECONDS=120

# Gemini OCR fallback for scanned/image-only PDFs.
# Uses GEMINI_API_KEY. No Tesseract or system OCR package is required.
# Designed for Render deployment where installing Tesseract is fragile.
GEMINI_OCR_ENABLED=true
GEMINI_OCR_MODEL=gemini-3.1-flash-lite
OCR_MIN_TEXT_THRESHOLD=300
MAX_OCR_PDF_SIZE_MB=20
OCR_MAX_PAGES=30
GEMINI_OCR_TIMEOUT_SECONDS=90

# Demo/testing trial credit default for newly created users only.
FREE_ANALYSIS_CREDITS_DEFAULT=15
