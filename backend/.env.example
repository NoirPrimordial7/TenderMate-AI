# Copy this file to backend/.env for local development.
# Never commit backend/.env or real secrets.

PROJECT_NAME=TenderMate AI Backend
FRONTEND_URL=http://localhost:3000
# In production, FRONTEND_URL should be the deployed Vercel URL.
# Optional comma-separated extra frontend origins.
CORS_ORIGINS=

SUPABASE_URL=
# Backend-only key. Do not expose SUPABASE_SERVICE_ROLE_KEY to the frontend.
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# Generate a strong local secret for JWT_SECRET_KEY before using auth.
# JWT_SECRET_KEY must be generated and kept secret.
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Security and quota defaults.
RATE_LIMIT_ENABLED=true
MAX_UPLOADS_PER_DAY=5
MAX_AI_ANALYSES_PER_DAY=3
FAILED_LOGIN_LOCK_THRESHOLD=5
FAILED_LOGIN_LOCK_MINUTES=15

# Gemini AI analysis. Backend-only; never expose this key to the frontend.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite
MAX_GEMINI_INPUT_CHARS=100000
GEMINI_REQUEST_TIMEOUT_SECONDS=60

# Demo/testing trial credit default for newly created users only.
FREE_ANALYSIS_CREDITS_DEFAULT=15
