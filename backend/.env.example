# Copy this file to backend/.env for local development.
# Never commit backend/.env or real secrets.

PROJECT_NAME=TenderMate AI Backend
FRONTEND_URL=http://localhost:3000
# In production, FRONTEND_URL should be the deployed Vercel URL.
# Optional comma-separated extra frontend origins.
CORS_ORIGINS=

SUPABASE_URL=
# Backend-only key. Do not expose SUPABASE_SERVICE_ROLE_KEY to the frontend.
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# Generate a strong local secret for JWT_SECRET_KEY before using auth.
# JWT_SECRET_KEY must be generated and kept secret.
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
